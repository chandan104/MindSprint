{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mindsprint/levels/v1/sequence_logic.config.json",
  "title": "Sequence Logic (sequential reasoning / planning) level config v1",
  "description": "Reserved module (gameplay unscheduled). The student arranges scrambled items into the correct order (size, number, or step sequences) or picks what comes next in a progression — measuring multi-step reasoning and planning rather than single-rule pattern matching.",
  "type": "object",
  "required": [
    "category_key",
    "logic_kinds",
    "question_count",
    "sequence_length",
    "time_limit_ms_per_question"
  ],
  "properties": {
    "category_key": { "type": "string", "minLength": 1 },
    "logic_kinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["arrange_order", "next_in_series", "reverse_order"] }
    },
    "question_count": { "type": "integer", "minimum": 3, "maximum": 15 },
    "sequence_length": { "type": "integer", "minimum": 3, "maximum": 8 },
    "time_limit_ms_per_question": { "type": "integer", "minimum": 10000, "maximum": 180000 }
  },
  "additionalProperties": false
}
