{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mindsprint/levels/v1/pattern_recognition.config.json",
  "title": "Pattern Detective (sequence completion / fluid reasoning) level config v1",
  "description": "The student sees a visual sequence following a rule (AB, ABC, AABB, mirror) with one missing slot and picks the item that completes it from the options.",
  "type": "object",
  "required": [
    "category_key",
    "pattern_kinds",
    "question_count",
    "sequence_length",
    "option_count",
    "time_limit_ms_per_question"
  ],
  "properties": {
    "category_key": { "type": "string", "minLength": 1 },
    "pattern_kinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["ab", "abc", "aabb", "abb", "mirror"] }
    },
    "question_count": { "type": "integer", "minimum": 3, "maximum": 20 },
    "sequence_length": { "type": "integer", "minimum": 4, "maximum": 10 },
    "option_count": { "type": "integer", "minimum": 2, "maximum": 6 },
    "time_limit_ms_per_question": { "type": "integer", "minimum": 5000, "maximum": 120000 }
  },
  "additionalProperties": false
}
