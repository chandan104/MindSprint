{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mindsprint/levels/v1/memory_recall.config.json",
  "title": "Memory Recall level config v1",
  "type": "object",
  "required": [
    "category_key",
    "sequence_length",
    "display_time_ms",
    "inter_item_gap_ms",
    "choice_grid_size"
  ],
  "properties": {
    "category_key": { "type": "string", "minLength": 1 },
    "sequence_length": { "type": "integer", "minimum": 2, "maximum": 12 },
    "display_time_ms": { "type": "integer", "minimum": 250, "maximum": 10000 },
    "inter_item_gap_ms": { "type": "integer", "minimum": 0, "maximum": 5000 },
    "choice_grid_size": { "type": "integer", "minimum": 4, "maximum": 16 },
    "trial_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Rounds per session (additive, default 1). Each round emits its own sequence_display_started/sequence_hidden pair into the shared session log."
    }
  },
  "additionalProperties": false
}
