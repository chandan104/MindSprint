{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mindsprint/levels/v1/attention_focus.config.json",
  "title": "Focus Tap (selective attention / go-no-go) level config v1",
  "description": "A stream of items appears one at a time; the student taps ONLY when the designated target appears and must withhold taps for everything else. target_ratio is the fraction of stimuli that are targets.",
  "type": "object",
  "required": [
    "category_key",
    "stimulus_count",
    "target_ratio",
    "display_time_ms",
    "inter_stimulus_gap_ms"
  ],
  "properties": {
    "category_key": { "type": "string", "minLength": 1 },
    "stimulus_count": { "type": "integer", "minimum": 5, "maximum": 60 },
    "target_ratio": { "type": "number", "exclusiveMinimum": 0, "maximum": 0.8 },
    "display_time_ms": { "type": "integer", "minimum": 300, "maximum": 5000 },
    "inter_stimulus_gap_ms": { "type": "integer", "minimum": 100, "maximum": 3000 }
  },
  "additionalProperties": false
}
